#Api2

# Override gtk theme
#Theme = "Adwaita-dark"

# Override gtk icon theme
IconTheme = "hicolor"

# Set default icon search path
Set ImagePath = "icons/misc"

# Set a hint for bar thickness (CSS should use this is calculate sizes).
Set ThicknessHint = "32px"

# Display minimized windows on taskbars across all outputs
# DisownMinimized = true

TriggerAction "SIGRTMIN+1", SwitcherEvent("forward");
TriggerAction "SIGRTMIN+2", SwitcherEvent("back");

Function SfwbarInit() {
#  Config "PopUp 'XVolumeWindow' { AutoClose = true }"
}

# Window Placer
placer {
  xorigin = 5  # place the first window at X% from the left
  yorigin = 5  # place the first window at X% from the top
  xstep = 5    # step by X% of desktop horizontally
  ystep = 5    # step by X% of desktop vertically
  children = true
}

# Task Switcher
switcher {
  disable = false
  interval = 700
  icons = true
  labels = false
  cols = 5
#  filter = workspace
}

include "winops.widget"

bar {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
#  size = "90%"
#  sensor = 300
#  sensor_delay = 500
#  transition = 800
#  monitor = "eDP-1"

  widget "startmenu.widget"
  widget "showdesktop.widget"

  pager {
    style = "pager"
    rows = 1
    pins = "1","2","3","4"
    preview = true;
    primary_axis = rows;
    action[Drag] = WorkspaceActivate();
  }


  taskbar {
    style = "taskbar"
    rows = 1;
    tooltips = true;
    icons = true;
    labels = true;
    title_width = 20;
    sort = false;
#    filter = workspace;
    action[RightClick] = Menu("winops");
    action[Drag] = Focus();
  }

# en empty label to take up any extra space between the taskbar and the tray
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

#  widget "cpu.widget"
#  widget "memory.widget"

  tray {
    rows = 1
  }
  widget "volume.widget" {
    simple_icon = True;
    volume_thresholds = [80, 50, 0];
    volume_icons = ["audio-volume-high", "audio-volume-medium", "audio-volume-low"];
    volume_muted = "audio-volume-muted";
  }

#  widget "bluez.widget" {
#    scan_timeout = 20;
#  }

  widget "ncenter.widget" {
    disable = true;
  }
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone";
    video_icon = "camera-web";
  }

  widget "language.widget"

  widget "session.widget" {
    session_actions = [
      ["hibernate", "Hibernate", "systemctl hibernate"],
      ["suspend", "Suspend", "systemctl suspend"],
      ["system-lock-screen", "Lock", "loginctl lock-session"],
      ["system-log-out", "Logout", "loginctl terminate-user $USER"],
      ["system-reboot", "Reboot", "systemctl reboot"],
      ["system-shutdown", "Shutdown", "systemctl poweroff"]
    ];
  }

  widget "clock.widget" {
    disable = false;
    time_format = "%H:%M"
    tooltip_format = "%H:%M\n%x"
    week_starts_on_sunday = false
    reset_on_popup = false
  }
}

#CSS
#hidden {
  -GtkWidget-visible: false;
}
#red { background-color: red; }

window#sfwbar {
  background-color: #1d1f21;
}

button,
button image {
  min-height: 0px;
  outline-style: none;
  box-shadow: none;
  background-image: none;
  border-image: none;
}

label {
  font-family: Sans;
  font-size: calc(@bar_thickness * 0.5);
}

image {
  -ScaleImage-symbolic: true;
}

.module,
button#startmenu,
button#module {
  border: none;
  padding: calc(@bar_thickness * 0.12);
  margin: 0px 3px;
  -GtkWidget-vexpand: true;
}

.module:hover,
button#startmenu:hover,
button#module:hover {
  background-color: rgba(129,162,190,0.15);
  color: #ffffff;
}

.module:hover image,
button#startmenu:hover image,
button#module:hover image {
  color: #ffffff;
}

.module image,
button#startmenu image,
button#module image {
  padding: 0px;
  margin: 0px;
  min-width: calc(@bar_thickness * 0.5);
  min-height: calc(@bar_thickness * 0.5);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  color: @theme_fg_color;
}

.focused {
  background-color: rgba(129,162,190,0.25);
  color: #ffffff;
}

.focused image {
  color: #ffffff;
}

button#taskbar_item.focused {
  border-bottom: 2px solid #81a2be;
}

.urgent label {
  color: red;
}

/* taskbar CSS properties */

button#taskbar_item {
  padding: calc(@bar_thickness * 0.1);
  border-radius: 0px;
  border-width: 0px;
  -GtkWidget-hexpand: false;
}

grid#taskbar > :not(:last-child) button#taskbar_item {
  border-radius: 0px;
  border-right: 1px solid alpha(@theme_fg_color,0.15);
}

button#taskbar_item.minimized label {
  color: alpha(currentColor, 0.6);
}

button#taskbar_item:hover {
  background-color: rgba(129,162,190,0.15);
  color: #ffffff;
}

button#taskbar_item grid {
  -GtkWidget-valign: center;
}

button#taskbar_item image {
  min-height: calc(@bar_thickness * 0.5);
  min-width: calc(@bar_thickness * 0.5);
  padding-right: calc(@bar_thickness * 0.25);
  padding-left: calc(@bar_thickness * 0.25);
  -ScaleImage-symbolic: false;
  -GtkWidget-vexpand: true;
}

button#taskbar_item label {
}

/* pager CSS properties */

grid#pager {
  border-radius: 0px;
  border: none;
  margin: 0px;
  padding: 0px;
}

button#pager_item {
  border-radius: 0px;
  border: none;
  outline: 0px;
  margin: 0px;
  padding: calc(@bar_thickness * 0.15) calc(@bar_thickness * 0.35);
  -GtkWidget-halign: fill;
  -GtkWidget-valign: fill;
  -GtkWidget-vexpand: true;
}

button#pager_item label {
  font-size: calc(@bar_thickness * 0.5);
}

button#pager_preview {
  border-radius: 0;
  border-color: #000000;
  border-width: 0.25mm;
  color: #777777;
  min-width: 5cm;
  min-height: 2.8125cm;
}

/* tray CSS properties */

button#tray_item {
  margin: 0px;
  border: none;
  padding: 0px;
}

button#tray_item.passive {
  -GtkWidget-visible: false;
}

button#tray_item image {
  min-width: calc(@bar_thickness * 0.5);
  min-height: calc(@bar_thickness * 0.5);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  padding: 3px 5px;
  margin: 0px;
  border: none;
}

/* switcher CSS properties */

window#switcher { 
  border: 1px solid @borders;
  border-radius: 6px; 
  padding: 60px; 
  -GtkWidget-hexpand: true;
}

grid#switcher_item.focused image,
grid#switcher_item.focused {
  background-color: #bbddff;
  color: #1d1d1d;
}

grid#switcher_item image,
grid#switcher_item {
  min-width: 50px;
  min-height: 50px;
  border-radius: 5px;
  padding: 5px;
  -GtkWidget-direction: right;
  -GtkWidget-hexpand: true;
  -ScaleImage-symbolic: false;
}

grid#switcher { 
  border-radius: 5px;
  padding: 5px;
  -GtkWidget-hexpand: true;
}

#app_menu_system #menu_item image {
  -ScaleImage-symbolic: false;
}

#menu_item,
#menu_item image,
#menu_item label {
  -GtkWidget-halign: start;
}

menuitem image {
  min-width: 16px;
  min-height: 16px;
  padding-right: 2px;
}

chart#cpu {
  background: rgba(127,127,127,0.3);
  min-width: 9px;
  -GtkWidget-vexpand: true;
  margin: 2px;
  border: 1px solid @theme_fg_color;
  color: red;
}

progressbar#memory {
  -GtkWidget-direction: top;
  -GtkWidget-vexpand: true;
  min-width: 9px;
  border: 1px solid @theme_fg_color;
  margin: 2px;
}

progressbar#memory trough {
  min-height: 2px;
  min-width: 9px;
  border: none;
  border-radius: 0px;
  background: rgba(127,127,127,0.3);
}

progressbar#memory progress {
  -GtkWidget-hexpand: true;
  min-width: 9px;
  border-radius: 0px;
  border: none;
  margin: 0px;
  background-color: alpha(green,0.9);
}

label#language {
  margin-left: 3px;
  margin-right: 5px;
}
