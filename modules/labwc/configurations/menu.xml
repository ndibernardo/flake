<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
  <menu id="root-menu" label="Root menu">
    <item label="Files" icon="org.xfce.thunar">
      <action name="Execute"><command>thunar</command></action>
    </item>
    <item label="Terminal" icon="com.mitchellh.ghostty">
      <action name="Execute"><command>ghostty</command></action>
    </item>
    <item label="Firefox" icon="firefox">
      <action name="Execute"><command>firefox</command></action>
    </item>
    <item label="Emacs" icon="emacs">
      <action name="Execute"><command>emacsclient -c -a ""</command></action>
    </item>
    <item label="Obsidian" icon="obsidian">
      <action name="Execute"><command>obsidian</command></action>
    </item>
    <item label="Steam" icon="steam">
      <action name="Execute"><command>steam</command></action>
    </item>
    <separator/>
    <item label="WhatsApp" icon="io.github.tobagin.karere">
      <action name="Execute"><command>karere</command></action>
    </item>
    <item label="Signal" icon="signal-desktop">
      <action name="Execute"><command>signal-desktop</command></action>
    </item>
    <item label="Telegram" icon="org.telegram.desktop">
      <action name="Execute"><command>Telegram</command></action>
    </item>
    <separator/>
    <item label="Screenshot Area" icon="applets-screenshooter">
      <action name="Execute">
        <command>sh -c 'grim -g "$(slurp)" -t png'</command>
      </action>
    </item>
    <separator/>
    <item label="Lock Screen" icon="system-lock-screen">
      <action name="Execute">
        <command>swaylock -f --screenshots --effect-blur 7x5 --effect-vignette 0.5:0.5 --clock --indicator --indicator-radius 120 --indicator-thickness 10 --ring-color 4f5459 --ring-ver-color 3584e4 --ring-wrong-color bf616a --key-hl-color 3584e4 --text-color ffffff --inside-color 00000088</command>
      </action>
    </item>
    <separator/>
    <item label="Reload Configuration">
      <action name="Reconfigure"/>
    </item>
    <item label="Logout">
      <action name="Exit"/>
    </item>
    <separator/>
    <item label="Reboot">
      <action name="Execute"><command>systemctl reboot</command></action>
    </item>
    <item label="Shutdown">
      <action name="Execute"><command>systemctl poweroff</command></action>
    </item>
  </menu>
</openbox_menu>
